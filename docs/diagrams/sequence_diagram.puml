@startuml
title Diagrama de Secuencia - Registrar una Compra
skinparam defaultFontSize 13
skinparam backgroundColor #F8F9FA

actor "Usuario" as user
participant "Navegador" as browser
participant "Vista" as view
participant "Formulario" as form
participant "Modelo" as model
database "Base de Datos" as db

user -> browser: Hace clic en Registrar Compra
browser -> view: GET /agricola/compras/create/
view -> form: Crea instancia de CompraForm()
form --> view: Retorna formulario vacio
view --> browser: Envia HTML del formulario
browser --> user: Muestra formulario en pantalla

user -> browser: Llena datos y envia
browser -> view: POST /agricola/compras/create/ con datos
view -> view: Valida permisos con login_required
view -> form: Valida datos con is_valid()
form --> view: Datos validos
view -> model: Crea instancia de Compra
model -> db: Inserta compra en base de datos
model -> model: Calcula el total
view -> model: Actualiza el stock del producto
model -> db: Actualiza producto en base de datos
view --> browser: Redirecciona con mensaje de exito
browser --> user: Muestra lista de compras actualizada

@enduml
