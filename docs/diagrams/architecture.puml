@startuml
title Arquitectura del Sistema por Capas
skinparam defaultFontSize 14
skinparam backgroundColor #F8F9FA

package "Capa de Presentacion" as presentacion {
  [Plantillas HTML] as templates
  [CSS / Bootstrap Local] as css
  [JavaScript / SPA] as js
}

package "Capa de Logica" as logica {
  [Vistas (Views)] as views
  [Formularios (Forms)] as forms
  [Decoradores de Roles] as decorators
}

package "Capa de Datos" as datos {
  [Modelos (Models)] as models
  [Migraciones] as migrations
}

database "Base de Datos" as db

templates --> views : Renderiza paginas
js --> views : Peticiones AJAX
views --> forms : Valida datos ingresados
views --> decorators : Controla acceso por roles
views --> models : Operaciones CRUD
forms --> models : Guarda datos en modelos
models --> db : Ejecuta consultas SQL
db --> models : Retorna resultados

@enduml
