@startuml
title Diagrama de Estados - Ciclo de Vida del Producto
skinparam defaultFontSize 13
skinparam backgroundColor #F8F9FA

[*] --> Borrador : Crear producto

Borrador --> Activo : Publicar con stock mayor a 0
Borrador --> [*] : Eliminar

Activo --> BajoStock : Venta reduce stock por debajo del limite
Activo --> Agotado : Venta reduce stock a 0
Activo --> [*] : Eliminar

BajoStock --> Activo : Compra aumenta el stock
BajoStock --> Agotado : Venta reduce stock a 0
BajoStock --> [*] : Eliminar

Agotado --> Activo : Compra aumenta el stock
Agotado --> [*] : Eliminar

state Borrador {
  [*] --> Editando : Crear instancia
  Editando --> Guardado : Formulario valido
}

state Activo {
  [*] --> Disponible : Stock mayor a 10
  Disponible --> EnDemanda : Stock entre 1 y 10
}

@enduml
