@startuml
title Diagrama de Clases - Sistema Agrícola

class Categoria {
  - id: int
  - nombre: string
  - descripcion: text
  - created_at: datetime
  - updated_at: datetime
  + __str__(): string
}

class Producto {
  - id: int
  - nombre: string
  - descripcion: text
  - precio: decimal
  - stock: int
  - imagen: image
  - created_at: datetime
  - updated_at: datetime
  + __str__(): string
}

class Compra {
  - id: int
  - cantidad: int
  - precio_unitario: decimal
  - total: decimal
  - fecha_compra: datetime
  + save(): void
}

class Venta {
  - id: int
  - cantidad: int
  - precio_unitario: decimal
  - total: decimal
  - fecha_venta: datetime
  + save(): void
}

class User {
  - id: int
  - username: string
  - email: string
  - password: string
  + groups(): ManyToMany
}

class Group {
  - id: int
  - name: string
  + permissions(): ManyToMany
}

Categoria "1" -- "0..*" Producto : contiene
Producto "1" -- "0..*" Compra : incluido_en
Producto "1" -- "0..*" Venta : vendido_en
User "1" -- "0..*" Compra : realiza
User "1" -- "0..*" Venta : registra
User "*" -- "*" Group : pertenece_a

@enduml
