@startuml
title Casos de Uso del Sistema Agricola
skinparam defaultFontSize 14
skinparam backgroundColor #F8F9FA

left to right direction

actor "Comprador" as comprador
actor "Vendedor" as vendedor
actor "Administrador" as admin
actor "Super Administrador" as superadmin

rectangle "Sistema Agricola" {
  usecase "Ver productos" as UC1
  usecase "Ver categorias" as UC2
  usecase "Gestionar Compras" as UC3
  usecase "Gestionar Productos" as UC4
  usecase "Gestionar Ventas" as UC5
  usecase "Gestionar Categorias" as UC6
  usecase "Exportar datos CSV" as UC7
  usecase "Ver Reportes" as UC8
  usecase "Gestionar Usuarios" as UC9
  usecase "Ver Dashboard" as UC10
  usecase "Configurar Sistema" as UC11
  usecase "Ver Auditoria" as UC12
  usecase "Crear Usuarios" as UC13
  usecase "Eliminar Usuarios" as UC14
  usecase "Autenticarse" as UC15
}

comprador --> UC1
