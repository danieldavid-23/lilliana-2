@startuml
title Patrones de Diseno del Sistema Agricola

package "Capa de Presentacion" as presentation {
  [MVC] as mvc
  [Adapter] as adapter
  [Template Method] as template
}

package "Capa de Logica" as logic {
  [Factory] as factory
  [Strategy] as strategy
  [Decorator] as decorator
  [Observer] as observer
  [Chain of Resp.] as chain
}

package "Capa de Datos" as data {
  [Singleton] as singleton
  [Proxy] as proxy
  [Repository] as repository
  [Command] as command
}

mvc --> adapter : Renderiza datos en HTML
adapter --> factory : Usa formularios
factory --> strategy : Valida con regex
decorator --> factory : Protege vistas
observer --> mvc : Notifica al usuario
chain --> decorator : Middleware
template --> adapter : Flujo de procesamiento
repository --> proxy : Consultas perezosas
singleton --> repository : Conexion unica a BD
command --> repository : Linea de comandos

@enduml
